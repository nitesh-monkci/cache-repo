# ── Required ──────────────────────────────────────────────────────────────────
CACHE_REPO_ID=1162393081
CACHE_ORG_ID=180827077
CACHE_BUCKET=temp-db-buck

# ── Optional (scope / branch isolation) ───────────────────────────────────────
# The git ref this server is caching for (e.g. the CI branch or PR ref)
CACHE_SCOPE=refs/heads/main

# Comma-separated list of scopes this server can READ from.
# Defaults to CACHE_SCOPE if not set.
# For PRs you may want: refs/pull/123/merge,refs/heads/main
CACHE_READ_SCOPES=refs/heads/main

# Scope this server can WRITE to. Defaults to CACHE_SCOPE.
CACHE_WRITE_SCOPE=refs/heads/main

# ── Optional (repo metadata) ───────────────────────────────────────────────────
CACHE_REPO_NAME=owner/repo

# ── Optional (server) ─────────────────────────────────────────────────────────
# Port to listen on. Use 443 for HTTPS (default), any other value for plain HTTP.
CACHE_PORT=443

# TLS certificate paths (required when CACHE_PORT=443)
CACHE_CERT_FILE=/etc/cache-server/server.crt
CACHE_KEY_FILE=/etc/cache-server/server.key

# ── GCS authentication ─────────────────────────────────────────────────────────
# Leave unset when running on GCE/GKE with a service account attached.
# Set to a service account key JSON file path otherwise.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# export CACHE_REPO_ID=1162393081
# export CACHE_ORG_ID=180827077
# export CACHE_BUCKET=temp-db-buck
# export CACHE_SCOPE=refs/heads/main